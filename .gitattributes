## Git LFS tracking rules for large datasets / archives
## Note: requires `git lfs install` on contributor machines.
data/**/*.tar.gz filter=lfs diff=lfs merge=lfs -text
data/**/*.tgz filter=lfs diff=lfs merge=lfs -text
data/**/*.tar filter=lfs diff=lfs merge=lfs -text
data/**/*.zip filter=lfs diff=lfs merge=lfs -text
